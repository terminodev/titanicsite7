[Unit]
Description=V2bX Service
After=network.target nss-lookup.target
Wants=network.target

[Service]
User=root
Group=root
Type=simple
LimitAS=infinity
LimitRSS=infinity
LimitCORE=infinity
LimitNOFILE=999999
WorkingDirectory=/opt/V2bX/
ExecStart=/opt/V2bX/V2bX server -c /opt/V2bX/config/config.json
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
